{
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "api:build": "node scripts/fix-generated-prisma-imports.mjs && tsc -p apps/api/tsconfig.json",
    "api:start": "node apps/api/dist/apps/api/src/main.js",
    "api:smoke": "npm run api:build && npx tsx scripts/api-smoke.ts",
    "frontend:auth-smoke": "npm run api:build && npm run build && npx tsx scripts/frontend-auth-smoke.ts",
    "api:typecheck": "tsc -p apps/api/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate && node scripts/fix-generated-prisma-imports.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:level2": "tsx prisma/seed-level-2.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
